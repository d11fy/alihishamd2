generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===========================
// Authentication
// ===========================
model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      AdminRole @default(ADMIN)
  avatar    String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("admins")
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  MODERATOR
}

// ===========================
// Scholarships
// ===========================
model Scholarship {
  id                 String            @id @default(cuid())
  title              String
  slug               String            @unique
  provider           String
  country            String
  city               String?
  degreeLevel        DegreeLevel[]
  scholarshipType    ScholarshipType
  fundingType        FundingType
  deadline           DateTime?
  status             ScholarshipStatus @default(ACTIVE)
  shortDescription   String            @db.Text
  fullDescription    String            @db.Text
  majors             String[]
  benefits           String[]
  requirements       String[]
  requiredDocuments  String[]
  applicationMethod  String?           @db.Text
  externalLink       String?
  coverImage         String?
  isFeatured         Boolean           @default(false)
  isPublished        Boolean           @default(false)
  sortOrder          Int               @default(0)
  viewCount          Int               @default(0)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  applications       ScholarshipApplication[]
  categories         ScholarshipCategory[]

  @@index([slug])
  @@index([isPublished, isFeatured])
  @@index([country])
  @@index([deadline])
  @@map("scholarships")
}

enum DegreeLevel {
  BACHELOR
  MASTER
  PHD
  DIPLOMA
  LANGUAGE_COURSE
  SHORT_COURSE
  ANY
}

enum ScholarshipType {
  FULLY_FUNDED
  PARTIALLY_FUNDED
  TUITION_ONLY
  LIVING_ALLOWANCE
  RESEARCH_GRANT
  EXCHANGE
}

enum FundingType {
  GOVERNMENT
  UNIVERSITY
  NGO
  PRIVATE
  INTERNATIONAL_ORGANIZATION
}

enum ScholarshipStatus {
  ACTIVE
  CLOSED
  COMING_SOON
  PAUSED
}

// ===========================
// Categories
// ===========================
model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  icon        String?
  color       String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  scholarships ScholarshipCategory[]

  @@map("categories")
}

model ScholarshipCategory {
  scholarship   Scholarship @relation(fields: [scholarshipId], references: [id], onDelete: Cascade)
  scholarshipId String
  category      Category    @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  categoryId    String

  @@id([scholarshipId, categoryId])
  @@map("scholarship_categories")
}

// ===========================
// Applications
// ===========================
model ScholarshipApplication {
  id              String            @id @default(cuid())
  scholarship     Scholarship       @relation(fields: [scholarshipId], references: [id])
  scholarshipId   String
  fullName        String
  phone           String
  email           String
  city            String
  gpa             String
  specialization  String
  desiredDegree   String
  notes           String?           @db.Text
  cvFile          String?
  transcriptFile  String?
  passportFile    String?
  extraFile       String?
  status          ApplicationStatus @default(NEW)
  adminNotes      String?           @db.Text
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([scholarshipId])
  @@index([status])
  @@index([email])
  @@map("scholarship_applications")
}

enum ApplicationStatus {
  NEW
  UNDER_REVIEW
  CONTACTED
  COMPLETED
  REJECTED
}

// ===========================
// Testimonials
// ===========================
model Testimonial {
  id          String   @id @default(cuid())
  studentName String
  subtitle    String
  testimonial String   @db.Text
  avatar      String?
  country     String?
  scholarship String?
  rating      Int      @default(5)
  isPublished Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("testimonials")
}

// ===========================
// Consultations
// ===========================
model Consultation {
  id        String             @id @default(cuid())
  fullName  String
  phone     String
  email     String
  message   String             @db.Text
  status    ConsultationStatus @default(NEW)
  adminNote String?            @db.Text
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  @@index([status])
  @@map("consultations")
}

enum ConsultationStatus {
  NEW
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// ===========================
// Contact Messages
// ===========================
model ContactMessage {
  id        String        @id @default(cuid())
  fullName  String
  phone     String?
  email     String
  subject   String
  message   String        @db.Text
  status    MessageStatus @default(UNREAD)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([status])
  @@map("contact_messages")
}

enum MessageStatus {
  UNREAD
  READ
  REPLIED
  ARCHIVED
}

// ===========================
// FAQ
// ===========================
model FAQ {
  id        String   @id @default(cuid())
  question  String
  answer    String   @db.Text
  category  String?
  sortOrder Int      @default(0)
  isPublished Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("faqs")
}

// ===========================
// Site Settings
// ===========================
model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  type      SettingType @default(TEXT)
  group     String   @default("general")
  label     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([key])
  @@index([group])
  @@map("site_settings")
}

enum SettingType {
  TEXT
  TEXTAREA
  JSON
  BOOLEAN
  IMAGE
  URL
  EMAIL
  PHONE
}
